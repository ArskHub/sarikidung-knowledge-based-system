  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanHyangBesakih_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilBukitMangu">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraBukitMangu_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDewaSangkara_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memuja Dewa Sangkara di Puncak Bukit Mangu untuk memohon peleburan dosa dan kotoran batin.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Bukit Mangu)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA BUKIT PANGELENGAN/ PURA BUKIT MANGU.
1.	Hyang Sangkara iku, Pangelengan Bukit, ica Ida nonton, Nodya saking, luhur nunas nugraha ne, Hyang kasuhun, Sinampura ugi, dosa Tri Kayeki, mangda I Ratu manglebur.

2.	Ratu Agung, cingak tityang sami, nunas jagat wrddhi nto, Maduluran, teleb bhakti ne, mangda lantur, Ngalimbakang suci, karahayon ring Bumi, saking stuti Maha A gung.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Bukit Mangu merupakan kidung pemujaan untuk pura yang berada di kawasan Bukit Mangu, Bedugul. Kidung ini menggambarkan kesakralan kawasan pegunungan Bedugul sebagai tempat bersemayamnya para dewa dan roh leluhur. Filosofi yang terkandung adalah penghormatan terhadap alam pegunungan yang sejuk sebagai sumber air kehidupan dan tempat yang paling dekat dengan kahyangan.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang tenang. Gaya: Sekar Madya. Catatan: Dinyanyikan dalam Piodalan di kawasan Bedugul.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraBukitMangu_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanDewaSangkara_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilGoaLawah">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraGoaLawah_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanBhataraBasuki_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memuja Bhatara Basuki sebagai penjaga keseimbangan bumi (Sapta Patala) agar tetap kokoh dan tidak guncang.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Goa Lawah)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA GOALAWAH
1.	Pura iku, Goa Lawah lewih, linggih Basuki reko, Madurgama, ngemban Pretiwine, Ida kukuh, Bumi ne kalilit,
Tan ginggang tan gingsir, sapta Patala ya kukuh.

2.	Sembah suhun, ledang nyanggra katon, mangda jagat, Majeng Hyang Pretiwi, terepti suka ne, langgeng lanus, Bhaktitur astiti, mangguh wiryya lan suci, Asih asung Hyang Pakulun.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Goa Lawah dipersembahkan di Pura Goa Lawah, salah satu Pura Sad Kahyangan Jagat yang terletak di Klungkung. Pura ini berdiri di depan gua yang dihuni ribuan kelelawar yang dianggap sakral sebagai manifestasi Naga Basuki. Kidung ini mengandung pemujaan kepada Dewa yang berstana di Goa Lawah sekaligus permohonan perlindungan dari kekuatan bawah tanah dan laut timur Bali.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, bernuansa mistis dan sakral. Gaya: Sekar Madya. Catatan: Khusus untuk Piodalan di Pura Goa Lawah.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraGoaLawah_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanBhataraBasuki_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilHayuLempuyang">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraHayuLempuyang_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanPasimpanganBhatari_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan di Pura Pasimpangan untuk memohon Ida Bhatara turun dari Puncak Lempuyang guna memberikan kesejahteraan.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Hayu Lempuyang)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA HAYU LEMPUYANG

1.	Pura hayu, pasimpangan Bhatari, ngayat Bhatara nto, 
Mangda turun, Bhatara Luhure, Lempuyangku, 
Nodya nyingak iki, nunas Krtha wrddhi, 
jagat Bali ajeg wibhuh.

2.	Tityang iku, sareng sami tangkil, ngatur bhakti reko, 
Ring bhukpadan, singgih Bhatara ne, ledang Sinuhun, 
Mapaica wrddhi, mala gempung bersih, 
tityang sami nunas kakuluh.

3.	Bhatara paum, nyari aturaniki, tedun lan manonton, 
Hyang Bhatara, lawan Hyang laluhure, mangda tulus,
Ngicen rahayuki, lan sarwa mahurip, 
Gemah ripah loh jinawiku.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Hayu Lempuyang adalah kidung pemujaan untuk Pura Lempuyang Luhur di Karangasem, yang merupakan pura arah timur dalam konsep Sad Kahyangan Jagat. Kata "hayu" berarti selamat atau indah, sehingga kidung ini merupakan permohonan keselamatan dari Bhatara yang berstana di Pura Lempuyang. Secara filosofis, kidung ini mencerminkan keyakinan bahwa pura-pura di puncak gunung adalah pintu gerbang menuju alam para dewa.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, anggun. Gaya: Sekar Madya. Catatan: Untuk Piodalan di Pura Lempuyang Luhur.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraHayuLempuyang_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanPasimpanganBhatari_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilKahyanganTiga">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraKahyanganTiga_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanTriSakti_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada manifestasi Tuhan di Kahyangan Tiga (Brahma, Wisnu, Siwa) sebagai pemelihara kehidupan di desa adat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Kahyangan Tiga)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA KAHYANGAN TIGA
Pupuh Mijil halus manis.
1.	Pura Agung, Pura Kahyangan Tigaki, 
Linggih Hyang Dewanto, Hyang Brahma, Wisnu.
Siwa Dewa ne, suci mulus, Sanghyang Tri Sakti, 
Ngemban jagat Tiga iki, mangda langgeng turing kukuh
2.	Sembah iku, maring jagat sami, Brahma pangurip nto, 
Hyang Wisnu dados pangembane, ring untatku, 
Siwa pangleburan jati, nika dados pancering, 
Maring jagat Bali iku.
3.	Bhakti mulus, majeng sira sami, Tiga Sakti ento, 
Ngawiwenang Bhuwana agunge, Ida sungsung.
Anggen pasayuban iki, bersih landuh suci 
Ida wantah maka tedung.
4.	Widdhi wibhuh, tunas tityang sami, Arta jagat Balinto, 
Paripurna, saisin jagate, mangda lebur, 
malan tityang sami, rahayu tunas puniki.
seger egar tityang samiku.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Kahyangan Tiga merupakan kidung pemujaan yang digunakan secara umum di Pura Kahyangan Tiga, yaitu tiga pura desa yang wajib ada di setiap desa adat Bali: Pura Desa/Bale Agung, Pura Puseh, dan Pura Dalem. Kidung ini mengandung makna pemujaan kepada Tri Murti: Brahma, Wisnu, dan Siwa yang masing-masing berstana di ketiga pura tersebut. Secara filosofis mencerminkan konsep keseimbangan alam semesta dalam tradisi Hindu Bali.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang. Gaya: Sekar Madya. Catatan: Dapat digunakan untuk Piodalan di semua pura Kahyangan Tiga.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraKahyanganTiga_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanTriSakti_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilLempuyang">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraLempuyang_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDewaIswara_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memuja Dewa Iswara di Gunung Lempuyang (Geni Jaya) untuk memohon kemakmuran.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Lempuyang)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA LEMPUYANG

1.	Pura Luhur, Lempuyang puniki, linggih Iswara rko, GENI JAYA, panyungsungan jagate, mangda wibhuh, Jagat maring Bali, sehananing hurip, rawuh turun saking luhur.

2.	Kirang katur, dupa canang sari, apang lda nonton, Nodya saking, linggih Bhatara ne, ne pakulun, Maduluran bhakti, siddha nangun trepti, asih Ida Hyang Kasuhun.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Lempuyang adalah kidung pemujaan khusus untuk Pura Lempuyang di Karangasem. Berbeda dengan Mijil Hayu Lempuyang, kidung ini lebih menekankan pada keagungan dan kekuasaan Bhatara Lempuyang sebagai penjaga arah timur Bali. Kidung ini berisi pujian terhadap keindahan alam Gunung Lempuyang dan permohonan berkah kepada para Bhatara yang berstana di puncaknya.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang khidmat. Gaya: Sekar Madya. Catatan: Untuk Piodalan di Pura Lempuyang.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraLempuyang_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanDewaIswara_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilPagonjongan">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraPagonjongan_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanBhataraBalingkang_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menghubungkan aspek historis Bhatara Balingkang dengan fungsi penyucian diri (mala letuh).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Pagonjongan)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA PAGONJONGAN
1.	Inggih Ratu, pura Pagonjongan, iki, Bhatara Balingkang rko, ring panegara Cinane, Ida kasub, mawisesa suci, Pasucian Bhatari, pangleburan mala letuh.

2.	Mangda Ratu, nyapuh tityang sami, mala jaba jero.
Asung asih Bhatara ne, mapisuguh antuk manah suci.
Ledang manywecanin, karahayon wrddhi landuh.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Pagonjongan merupakan kidung yang dipersembahkan di Pura Pagonjongan. Kidung ini mengandung makna pemujaan kepada Bhatara yang berstana di pura tersebut beserta permohonan perlindungan dan keselamatan bagi seluruh umat yang bergantung pada pura ini sebagai pusat kehidupan spiritual mereka.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang. Gaya: Sekar Madya. Catatan: Untuk Piodalan di Pura Pagonjongan.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraPagonjongan_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanBhataraBalingkang_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilRambutSiwi">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraRambutSiwi_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanRsiNirartha_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menghormati Rsi Nirartha di Pura Rambut Siwi, memohon kebijaksanaan dan perlindungan bagi seluruh makhluk.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Rambut Siwi)</judulKidung>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA RAMBUT SIWI
1.	Ida Ratu, Rsi Nirartha linggih, Pura Rambut Siwi Ento, rambut Ida, sungsungan jagate, pedek rawuh, Ring bukpada Resi, sarwa bhawa hurip,
Mangda krtha sane pangguh.
2.	Ne karuruh, ledang Ratu ngemban iki, jagat Bali reko, Ajeg Bali, prasiddha panggih ne, pageh tuhu, Kepradnyanan suci, skala niskala uning, Rsi Nirartha dahat sadhu.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Rambut Siwi dipersembahkan di Pura Rambut Siwi di Jembrana, pura yang didirikan oleh Danghyang Nirartha dan dianggap sebagai tempat keramat yang menyimpan rambut beliau. Kidung ini mengandung pemujaan kepada Danghyang Nirartha sebagai tokoh yang menyebarkan ajaran Hindu di Bali, serta permohonan berkah kepada Bhatara yang berstana di pura tersebut menghadap Samudra Hindia.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, dengan nuansa laut dan ketenangan. Gaya: Sekar Madya. Catatan: Untuk Piodalan di Pura Rambut Siwi.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraRambutSiwi_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanRsiNirartha_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilTanahLot">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraTanahLot_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanBhataraSegara_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memohon kerahayon (keselamatan) bagi seluruh jagat Bali dan pembersihan hati (jaba jero).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Tanah Lot)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA TANAH LOT
1.	Bhakti mulus, Bhatara Blatari, ring Pura Tanah Lot, Cingak sembah, bhaktin tityange, sweca Ratu, Manodyanin bumi, nicen rahayu iki,
sejagat Bali mahayu.

2.	Ledang Ratu, maicayang wrddhi, nunas wasuh cokor, Mangda bersih, jabajro hrdaya ne, taler puguh, Tleban manah jati, mangda siddha kapti,
Kadharman buddhi puniku.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Tanah Lot adalah kidung pemujaan untuk Pura Tanah Lot di Tabanan, salah satu pura paling terkenal di Bali yang berdiri di atas batu karang di tengah laut. Pura ini merupakan salah satu dari tujuh pura kahyangan di wilayah pesisir Bali yang didirikan oleh Danghyang Nirartha. Kidung ini mengungkapkan kekaguman terhadap keindahan pura yang dikelilingi ombak laut serta pemujaan kepada Dewa laut yang berstana di sana.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, mengalir seperti ombak laut. Gaya: Sekar Madya. Catatan: Untuk Piodalan di Pura Tanah Lot.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraTanahLot_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanBhataraSegara_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilUlunDanu">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUlunDanu_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDewiDanu_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada Dewa Wisnu dan Dewi Danu sebagai penguasa air dan kesuburan untuk kemakmuran jagat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Ulun Danu)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA ULUN DANU
1.	Sanghyang Wisnu, Dewi Danuh linggih, Ulun Danu ento Jagat wibhuh, kancan isin jagate, sweca Ratu, manibakang luwih, Ngangganin ya sami, mangda lda ngawe landuh.

2.	Wreddhi iku, tityang sareng sami, i ketunan Om, Dumadak ja, jua keaksi ne, bhakti mulus, nunas wasuh iki, ne mraga suci, mangda dirgayusa hayu.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Ulun Danu dipersembahkan di Pura Ulun Danu, pura yang secara khusus memuliakan Dewi Danu sebagai dewi danau dan kemakmuran pertanian. Berbeda dengan Mijil Batur, kidung ini lebih berfokus pada aspek air danau sebagai sumber kehidupan yang suci. Secara filosofis, kidung ini merupakan ungkapan rasa syukur dan penghormatan kepada alam air yang menghidupi semua makhluk di Bali.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang mengalir tenang. Gaya: Sekar Madya. Catatan: Untuk Piodalan di Pura Ulun Danu.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraUlunDanu_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilUluwatu">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUluwatu_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanHyangRudra_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada Dewa Rudra sebagai penguasa samudra dan penjaga keseimbangan Bhuwana Agung.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Uluwatu)</judulKidung>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA HULUWATU
1.	Huluwatu, Hyang Rudra Luwih, Kesama Swamam Ong Ida ngemban, maring segara ne, Bhuwana A gung Ngawinang sami, daging tasik iki, nunas krta wrddhi wibhuh.

2.	Sweca Ratu, ledang manywecanin, nibakang rahayon, Tityang sami, taler, sareng jagate, ne kawuwus,
Ida sayang iki, hayu wradhi trepti. saking astuti mahagung.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Uluwatu dipersembahkan khusus untuk pemujaan di Pura Luhur Uluwatu, salah satu Pura Sad Kahyangan Jagat yang terletak di tebing karang selatan Bali. Kidung ini menggambarkan keagungan Pura Uluwatu sebagai tempat pemujaan Dewa Rudra dan penjaga laut selatan Bali. Secara spiritual, kidung ini mengandung permohonan perlindungan dari kekuatan laut dan angin, serta penghormatan kepada Danghyang Nirartha yang menjadikan Pura Uluwatu sebagai tempat pemuktian beliau.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, dengan nuansa megah dan agung. Gaya: Sekar Madya, dilantunkan dengan penuh penghayatan. Catatan: Khusus dinyanyikan dalam upacara Piodalan di Pura Luhur Uluwatu.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraUluwatu_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

