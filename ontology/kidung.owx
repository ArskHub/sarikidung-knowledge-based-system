  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanDalemSolo_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_AlisAlisIjo_Pengayat">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <memilikiMakna rdf:resource="#PenyambutanDewa_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit"/>
  <digunakanPadaUpacara rdf:resource="#UpacaraUmum_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung untuk memohon kehadiran Ida Bhatara agar menyambut bakti umat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alis-alis Ijo Bawak (Dewa Yadnya)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mangda kayun kehayata, Hyang Bhatari Hyang Bhatara, Ledang nyanggra, bhakti katon, prapta maring Sanghyang Widhi, nunas rahayu, majeng Bhatara, Ida sayang ne kawuwus, hayu wrddhi, Hyang Kasuhun, moga sida ngawe trepti, gelis turun manyongsong.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Alis-Alis Ijo Pengayat adalah kidung khusus untuk tahap pengayat, yaitu penyambutan kehadiran Bhatara saat turun ke pratima atau pralingga. Nama "Alis-Alis Ijo" menggambarkan alis hijau yang menjadi ciri khas kecantikan dewi-dewi dalam ikonografi Hindu Bali. Kidung ini berfungsi sebagai undangan yang tulus dan penuh bhakti agar para Bhatara berkenan hadir dan menerima persembahan umat.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Alis-Alis Ijo. Tempo: Sedang, menyambut dan lembut. Gaya: Sekar Alit. Catatan: Dinyanyikan pada tahap pengayat Bhatara, saat pratima atau pralingga dibawa ke palinggih.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alis-Alis Ijo</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PenyambutanDewa_Ref"/>

<owl:NamedIndividual rdf:about="#DewaYadnya_Umum_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_BhataraMantukSakingMasucian">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraDesa_Ref"/>
  <digunakanPadaTahap rdf:resource="#PenutupUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Melasti_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Pengembalian_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan saat Bhatara kembali ke pura setelah masucian</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bhatara Mantuk Saking Masucian</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Panca Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">6.	Bhatara Mantuk Saking Masucian
Wirama Indra Wangsa :
--0/--0/0 - 0/- 00=12

1.	Amwitnarendratmaja ring tapowana,
manganjali ryagraning indra parwata, 
Tan wismıti sangkanikang hayun teka, 
Swabhawa sang sajjana rakwa mangkana.
2.	Mangkat dateng tolih arum wulat nira, 
Sinambaying camara sangkaring geger, 
Panawwanging mrak panangis nikang halas, 
Erang tininggal masaput-saput hima.

Wirama Wirat Tebusol (Wikerti)
00-/0-0/00-/000/000/-0-/00=20
3.	Kadi harsaning taru latangelih angayam-ayam labuh kapat,
Sukaning sakendran 1 dateng nrpasuta kadi tambaying hudan,
Nguni weh tikang sura wadhu dumadak asemikungnya de nira,
Katering pater padani wittanira lagi ri nengwa rengwaken.
4.	Sura kanyakasahananing kararan atiki tan hana ngunggang, kadi tan mapatra turidanya linaca lacaning kakanghyasi,
Awingit-wingit sinurunyan dali-dali hana ring ranging hati,
Agelem ta ya naluk aken sahaja cala tinagwatagwaken.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Bhatara Mantuk Saking Masucian dinyanyikan saat Bhatara kembali (mantuk) setelah prosesi masucian atau penyucian. Kidung ini mengandung makna pelepasan dan pamitan kepada Bhatara yang telah hadir dalam upacara dan kini kembali ke kahyangan. Secara filosofis, kidung ini mencerminkan siklus kehadiran dan kepergian para dewa dalam kehidupan ritual umat Hindu Bali yang bersifat sementara namun meninggalkan berkah abadi.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Sragdhara. Tempo: Lambat, penuh rasa hormat dan haru. Gaya: Sekar Madya. Catatan: Dinyanyikan pada tahap penutupan upacara setelah Bhatara kembali dari prosesi masucian.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sragdhara</polaMelodi>
</owl:NamedIndividual>

