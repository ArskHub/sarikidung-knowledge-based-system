<owl:NamedIndividual rdf:about="#Kidung_ManusaYadnya_WiramaMalat">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Rumah_Ref"/>
