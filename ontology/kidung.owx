<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_DalemSolo">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraDalemSolo_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanRaja_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung khusus yang ditujukan untuk memuja manifestasi Ida Bhatara yang berstana di Pura Dalem Solo.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Alis-Alis Ijo Bawak (Kidung Dalem Solo)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ALIS-ALIS IJO BAWAK
1.	Prapteng sira rahadyan, jenek maring linggih sira, endi mararem, sira Dalem Solo, semu egar ne wirage, kangen ngatonang, ranak rangrong, winuwus Irakajeng anom, amuji iki, sanak ingsun, malungguhmaring Jawi,
Prabhusira Dalem Solo.

2.	Egar kahyun kahayata, lumra manibakang krta, subaga wiryya, landuh katon, Sri Bhupati nene mangkin, tusta nagara, Wali Pulo, linuhung suka nikang wong, lan sastrawit, jagat mahayu, tentrem pradnyan kang ulati, kapti Sira Dalem Solo.

3.	Mangd kahyun kahayata, Hyang Bhatari Hyang Bhatara, ledang nyangra, bhakti katon, prapta maring Sanghyang Widhi, nunas rahayu majeng Bhatara, Ida sayang ne kawuwus, hayu wredi Hyang Kasuhun, sida moga ngawe trepti, gelis turun manywecanin.

4.	Sweca Ida manibakang, karahayon maring jagat, taler ring hrdaya jaba jero, kreta anduh kanginapti, pada suka mangguh wiryya, mangda Bhatara mabawos, saking astute maha agung, ngawe ledang Sanghyang Widhi, Ida ica manonton.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dalem Solo merupakan kidung yang memiliki hubungan dengan tradisi keraton Solo dan pengaruh budaya Jawa dalam perkembangan kidung Bali. Kidung ini mengandung nuansa mistis yang kuat berkaitan dengan pemujaan kepada Bhatara Dalem sebagai manifestasi kekuatan transformasi dan kematian. Secara historis, kidung ini mencerminkan akulturasi budaya Jawa-Bali yang terjadi pasca kejatuhan Majapahit.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Dalem Solo. Tempo: Lambat dan mistis. Gaya: Sekar Alit. Catatan: Dinyanyikan dalam konteks pemujaan kepada Bhatara Dalem.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dalem Solo</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanRaja_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_DangdangGendis">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUmum_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#PemujaanUmum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Pemujaan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan sebagai pembuka pemujian, menggambarkan ketulusan hati dalam menyembah Sang Hyang Widhi.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Dangdang Gendis (Amad)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PUPUH DANGDANG GENDIS/AMAD
Om ksantawya purwaning pamuji, 
Apan prasangga angayat Bhatara, 
Sang amurbeng Tri Lokane, 
Tingalana pukulun, 
Sembahing astiti bhakti, 
Puspa maka sarana, 
Pangarcananing ati jugul, 
Saha jnana lila suddha, 
Mangradana,
Sang pakestining kumilip, 
Sang anyuksmeng sahana.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dangdang Gendis merupakan salah satu kidung paling populer dan sering digunakan dalam berbagai upacara Dewa Yadnya. Kidung ini memiliki makna yang sangat luas sebagai kidung pemujaan umum yang mengandung puji-pujian kepada Ida Sang Hyang Widhi dalam berbagai manifestasi-Nya. Secara filosofis, Dangdang Gendis mencerminkan keindahan (gendis berarti manis atau indah) pemujaan yang tulus dari hati yang bersih.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Dangdang Gendis (10i-10a-8e-7u-9i-7a-6u). Tempo: Sedang, manis dan mengalir. Gaya: Sekar Madya, dinyanyikan dengan suara yang merdu dan ekspresif. Catatan: Dapat digunakan di berbagai tahap upacara Dewa Yadnya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dangdang Gendis (10i-10a-8e-7u-9i-7a-6u)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanUmum_Ref">
  <rdf:type rdf:resource="#UpacaraPancaYadnya"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pemujaan_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_DangdangGendis_Pengaksama">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUmum_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#UpacaraUmum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanPengampunan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan di awal upacara untuk memohon pengampunan atas kelancangan dan keterbatasan manusia dalam memuja Tuhan.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dangdang Gendis (Pengaksama)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PENGAKSAMA
Pupuh Dangdang Gendis/Amad.

Om ksantawya purwaning pamuji, apan prasangga angayat Bhatara,
Sang amurbeng Tri Lokane, tinghalana pukulun, Sembahing astiti bhakti, puspa maka sarana, pangarcaning ati jugul,
Saha jnana lila suddha, mangredana, sang pakestining kumelip,
Sang anyuksmeng sahana.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dangdang Gendis Pengaksama adalah versi khusus dari Dangdang Gendis yang digunakan sebagai kidung pengaksama, yaitu permohonan maaf dan izin kepada Bhatara sebelum upacara dimulai. Pengaksama merupakan bagian yang sangat penting dalam tatacara upacara Hindu Bali karena menunjukkan kerendahan hati dan kesadaran bahwa manusia tidak lepas dari kekhilafan. Kidung ini memohon agar Bhatara berkenan menerima persembahan meskipun tidak sempurna.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Dangdang Gendis (10i-10a-8e-7u-9i-7a-6u). Tempo: Lambat, penuh kerendahan hati. Gaya: Sekar Madya, dilantunkan dengan tulus dan khidmat. Catatan: Dinyanyikan di awal upacara sebagai tahap pengaksama sebelum pemujaan inti.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dangdang Gendis (10i-10a-8e-7u-9i-7a-6u)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanPengampunan_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Magatruh">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUmum_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#PemujaanUmum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PermohonanMaaf_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Berisi permohonan maaf atas segala kekurangan, ketidaktahuan, dan keterbatasan dalam sarana upacara.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Magatruh (Pengaksama ring Bhatara)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PUPUH MAGATRUH
1.	Antur tityang para pamedek 
lintang jugul,
Panembahe ring Hyang Widhi, 
Tan pamantra tan pasuguh, 
Bhakti antuk manah eling, 
Eling maring raga belog
2.	Mangke walia Ira sraya sembah ingsun, 
Ksama ya tan pangesti, 
Asung asih Hyang Pakulun, 
Manugraha maring mami, 
Mangda kasidan don.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Magatruh merupakan salah satu pupuh Bali yang memiliki nuansa melankolik dan penuh ketulusan. Nama Magatruh berasal dari kata "magat" (memotong) dan "ruh" (jiwa), sehingga secara filosofis kidung ini menggambarkan pemotongan ikatan duniawi untuk mencapai kebebasan spiritual. Dalam konteks Dewa Yadnya, kidung Magatruh digunakan sebagai ungkapan penyerahan diri secara total kepada Sang Hyang Widhi.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Magatruh (12u-8i-8u-8i-8o). Tempo: Sedang cenderung lambat, melankolis. Gaya: Sekar Madya. Catatan: Cocok untuk tahap kontemplasi dalam upacara.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Magatruh (12u-8i-8u-8i-8o)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PermohonanMaaf_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilAndakasa">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraAndakasa_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDewaBrahma_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan Dewa Brahma di Pura Andakasa, fokus pada permohonan ampun atas dosa Tri Kaya Parisudha.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Andakasa)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA ANDAKASA
1.	Brahma iku, jenek Ida linggih, Pura Andakasa mon, Tityang jugul, ngaturang gurite, Hyang Kaluhur, Sinampura ugi, dosa Tri Kayaki, kesama swamam pukulun.

2.	Ida Ratu, cingak bhakti iki, tityang kerahayon, Angarcana, Ida Bhatara ne, ne kaluhur, sida nangun trepti, madulur astiti, saterusa ican Iratu.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Andakasa adalah kidung pemujaan yang dipersembahkan di Pura Andakasa, sebuah pura kahyangan di wilayah Karangasem. Kidung ini menggambarkan keindahan dan kesucian pura yang berada di ketinggian, serta permohonan berkah kepada Bhatara yang berstana di sana. Filosofi yang terkandung adalah hubungan manusia dengan alam pegunungan sebagai tempat yang suci dan sakral dalam tradisi Hindu Bali.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang mengalir. Gaya: Sekar Madya. Catatan: Dinyanyikan dalam upacara Piodalan di Pura Andakasa.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraAndakasa_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanDewaBrahma_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilBanua">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraBanua_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanBhataraKadalon_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan tulus kehadapan Bhatara yang berstana di Pura Banua untuk kelancaran upacara.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Banua)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA BANUA
1.	Pura Agung, Pura Banua pamuji, Bhatara kadalon, Nyingak bhaktin, tityang sami ne, ne pakulun, Sembahing astiti, pangarcana Widhi, lila suddha majeng Ratu.

2.	Pura Ulu, Pura Hyang Pingit, panyungsungan ento, Nyungsung ngayat Bhatara ne, mangda tumus, Antuk jnana eling, pangestining hati, Jong Bhatara dirghayuh.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Banua merupakan kidung yang dipersembahkan dalam konteks upacara Dewa Yadnya untuk pemujaan di pura-pura wilayah tertentu. Kidung ini mengandung makna penghormatan kepada Bhatara penjaga wilayah (banua) dan permohonan keselamatan serta kemakmuran bagi seluruh masyarakat yang bernaung di bawah perlindungan pura tersebut. Secara filosofis mencerminkan konsep Tri Hita Karana dalam hubungan harmonis antara manusia dengan Tuhan.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang. Gaya: Sekar Madya. Catatan: Dinyanyikan pada upacara Piodalan.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraBanua_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanBhataraKadalon_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilBatur">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraBatur_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDewiDanu_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada Dewi Danu sebagai penguasa danau dan sumber air untuk kesuburan jagat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Jati / Batur)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA JATI/BATUR
1.	Pura Batur, Pura Jati Suci, linggih Dewi Danuh, reko Kekaryanin, Jaya Mahireng Iwih ne, jana tinut, Ida Balingkang iki, Ida Bhatara sakti, Ring Tampurhyang puniku.

2.	Ta pakulun, sredha sembah bhakti, tityang sami katon, Mangda trepti, jagat Bali ne, tityang tandruh, Ngayat Bhatara iki, ledang ja Bhatari, Manibakang sarwa landuh.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Batur dipersembahkan khusus di Pura Ulun Danu Batur, salah satu Pura Sad Kahyangan Jagat yang berstana di tepi Danau Batur, Kintamani. Kidung ini mengisahkan keagungan Dewi Danu sebagai dewi air dan kesuburan yang menghidupi seluruh pertanian di Bali. Secara filosofis, kidung ini merupakan ungkapan syukur petani Bali atas berkah air yang mengalir dari Gunung Batur melalui sistem pengairan subak yang telah berlangsung ribuan tahun.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, khidmat dan penuh rasa syukur. Gaya: Sekar Madya. Catatan: Khusus untuk Piodalan di Pura Ulun Danu Batur.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraBatur_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanDewiDanu_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilBesakih">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraBesakih_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanHyangBesakih_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menceritakan sejarah Rsi Markandeya dan status Pura Besakih sebagai pusat pemujaan di Bali.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Besakih)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Mijil Alus Manis.

1.	Pura agung, Pura Hyang Besakih, sungsungan jagat nto, 
Linggih dumun, ring Pulo Jawine, ring Semeru, 
MARKENDYA gingsir, Gunung Agung iki, 
sami jagat Bali nyungsung.

2.	Pnataran gung, Padma Tiga iki, stana Widhi reko, 
Siwa Sada, Siwa Parama Siwa ne, akeh Meru, 
Linggih Hyang Bhatari, jejer ngulangunin, 
nunas nugraha lan Wibhuh.

3.	Odalanku, ring Kadasa Sash, Purnama siddhi nto,
Mejalan bhakti ajeg Bali ne, kerahayon,
Sane pedek iki, Ida asung asih, jagat Bali wrddhi landuh.

4.	Tityang iku, astiti janeki, sreddhaning lampahku, 
Antuk manah, galang tityange, mangda kukuh, 
Sembah Sanghyang Widhi, paicayang indik suci, 
Santi Santi Santi Om.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Besakih merupakan kidung pemujaan yang khusus dipersembahkan di Pura Agung Besakih sebagai Kahyangan Jagat tertinggi di Bali. Kidung ini mengisahkan keagungan dan kesucian Pura Besakih sebagai pusat spiritual Pulau Dewata yang didirikan oleh Rsi Markandeya. Secara filosofis, kidung ini menegaskan hubungan spiritual antara manusia Bali dengan Ida Sang Hyang Widhi Wasa yang berstana di pura tersebut. Melantunkan kidung ini merupakan wujud bhakti tertinggi dan pengakuan atas kebesaran Sang Hyang yang bersemayam di puncak Gunung Agung.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, penuh penghayatan dan keagungan. Gaya: Sekar Madya, dinyanyikan dengan suara merdu dan khidmat. Catatan: Dinyanyikan pada tahap puncak upacara saat pratima distanakan di pelinggih utama Pura Besakih.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

