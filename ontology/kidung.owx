<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_AlisAlisIjoDalemSolo">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraDalemSolo_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDalemSolo_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menghormati manifestasi Prabhu Dalem Solo dalam konteks sejarah leluhur Jawa-Bali.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alis-Alis Ijo Bawak (Pura Dalem Solo)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Leluhur</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Prapteng sira rahadyan, jenek maring linggih sira, Endi mararem, Sira Dalem Solo, semu egar ne wirage, Kangen ngatonang, amuji iki, sanak ingsun, Malungguh maring Jawi, Prabhu Sira Dalem Solo.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Alis-Alis Ijo Dalem Solo merupakan kidung yang memadukan dua tradisi kidung: Alis-Alis Ijo sebagai kidung pengayat (penyambutan) dengan nuansa Dalem Solo yang berasal dari pengaruh budaya Jawa-Bali. Kidung ini mengandung makna penyambutan kehadiran Bhatara Dalem, manifestasi Dewa yang berkaitan dengan kematian dan transformasi spiritual. Secara filosofis mencerminkan koneksi antara dunia manusia dengan dunia para dewa melalui lantunan suara yang suci.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Alis-Alis Ijo. Tempo: Sedang, mengalir lembut. Gaya: Sekar Alit. Catatan: Dinyanyikan sebagai kidung pengayat dalam upacara Dewa Yadnya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alis-Alis Ijo</polaMelodi>
</owl:NamedIndividual>

