<owl:NamedIndividual rdf:about="#Kidung_PitraYadnya_MalatRasmi">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Setra_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Ngaben_Ref"/>
  <memilikiJenisYadnya rdf:resource="#PitraYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PerjalananAtma_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menggambarkan perjalanan Atma menuju pintu akhirat dan percakapan dengan para penjaga pintu suci.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Malat Rasmi (Kancing Kori)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Pitra Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MALAT RASMI
1.	Sira sang atunggun kori,
Bungkahana kancing kori, 
Sang Cikrabala amuwus,
Atma paran sira prapti.

2.	Warahana sira tuwi, 
Sang atma sumahur manis,
Duh singih pukulun,
Pan tutur menget ingsun prapti,

3.	Ken Dorakala nyawurin, 
Sapa ngaran ikang bibi, 
Mwang bapa ira tuhu, 
Pan tutur menget angling.

4.	Sang atma sumawur aris, 
Ibunira Sanghyang Anis, 
Bapanira Sanghyang Putus, 
Ingsun Snghyang Lepas iki.

5.	Sira Jogormanik angling, 
Cikrabala anyawurin,
Sang atma sira muwus,
Dorakala angucap aris.

6.	Ingsun iki den arani, 
Sapa aran sun iki,
Sang atma sira muwus, 
Wuwusane angasih-asih.

7.	Sira Suratma kadang mami,
Kula ta kita ari-ari, 
Antapreta sira iku, 
Ring papusuhan ingsun iki.

8.	Aranana sira malih, 
Sapa aran sanak mami, 
Sang atma mangke muwus, 
Mangke ingsun angaranin.

9.	Sira ngaran Jogormanik, 
Getih ingsun sira nguni, 
Cikrabala punika, 
Yeh Nyom sira nguni.

10.	Miwah Dorakala iki, 
Lamas ingsun nguni, 
Pun maka lawangan pukulun, 
Bapa ibu ingsun nguni.

11.	Bapa sira Nareswara iki, 
Mwah ibun sira Nareswari, 
Hyang Brahma Wisnu pukulun, 
Bungkahana kancing kori,

12.	Sira Sang atunggun kori, 
Nulya mungkah kancing kori, 
Sira sang atma anyusup, 
Inapagin Widyadari.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Malat Rasmi menggunakan wirama dari Kidung Malat, salah satu karya sastra Bali yang terkenal. Rasmi berarti sinar atau cahaya, sehingga kidung ini mengandung permohonan agar cahaya kebijaksanaan Sang Hyang Widhi menerangi jalan sang atma. Dalam tradisi Pitra Yadnya, kidung ini mengiringi prosesi dengan doa agar leluhur mendapatkan pencerahan sejati di alam sana.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Malat Rasmi. Tempo: Sedang. Gaya: Sekar Madya. Catatan: Dinyanyikan dalam rangkaian upacara ngaben.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Malat Rasmi</polaMelodi>
</owl:NamedIndividual>

