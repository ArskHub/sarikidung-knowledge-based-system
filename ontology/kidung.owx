  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Sragdhara_Masucian">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Beji_Ref"/>
  <digunakanPadaTahap rdf:resource="#ProsesiMasucian_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PenyambutanKedatanganDewa_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan saat prosesi penyucian (masucian) arca atau pratima, menggambarkan hujan bunga dari langit dan gema mantra Ongkara.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Sragdhara (Bhatara Masucian)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gita Pemujaan</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ngka lumrang puspa warseng ghana sinahur aken sang watek siddha Sanggha, lawan Ongkara Mantra jaya rijaya sri maha Pandhuputra, Mantrang warsararab manggala nilaku nirapangruhunsedhungadres, Apan Sanghyang Surendradulur ing awang awang mastwaken yan jayeng prang.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Sragdhara Masucian menggunakan wirama Sragdhara untuk mengiringi tahap masucian atau penyucian dalam upacara. Masucian adalah prosesi penyucian ritual yang melibatkan air suci dan mantra-mantra penyucian. Kidung ini berfungsi untuk menciptakan suasana sakral yang mendukung proses penyucian jiwa dan raga peserta upacara.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Sragdhara. Tempo: Lambat, khidmat dan menyucikan. Gaya: Sekar Madya. Catatan: Dinyanyikan pada tahap masucian dalam rangkaian upacara Dewa Yadnya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sragdhara</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Beji_Ref"/>

<owl:NamedIndividual rdf:about="#ProsesiMasucian_Ref">
  <urutanTahap rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</urutanTahap>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PenyambutanKedatanganDewa_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Sragdhara_Pengayat">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#DewaYadnya_Umum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanSastraSuci_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama pemujaan tingkat tinggi yang mengagungkan sastra suci sebagai bentuk Dewa.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Sragdhara (Pengayat Ring Bhatara)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gita Pemujaan</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ndah mangka kottaman Sri Yatiwarakarengo murttining guhya sastra, manggeh manggalyaningmrakreta sarasa nikang asta kandhadi mukya, yeka kangken maha padmala nika sargganing asta kanda, suksmaning parwwa yangkenari sari nikanang kamatantra pamuja.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Sragdhara Pengayat menggunakan wirama Sragdhara untuk mengiringi tahap pengayat atau penyambutan Bhatara. Kidung ini menggabungkan keindahan wirama Sragdhara yang agung dengan fungsi pengayat yang menyambut kehadiran para dewa. Secara filosofis mencerminkan kegembiraan dan antusiasme spiritual umat dalam menyambut kehadiran Bhatara yang mulia.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Sragdhara. Tempo: Sedang, antusias dan menyambut. Gaya: Sekar Madya. Catatan: Dinyanyikan pada tahap pengayat Bhatara.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sragdhara</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanSastraSuci_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariBelatungan">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraBelatungan_Ref"/>
  <digunakanPadaTahap rdf:resource="#NunasTirtha_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanPrabhuBelatungan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memohon penyucian diri di Pura Belatungan agar mendapatkan ketenangan jagat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Belatungan)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pura Blatungan linggih Prabhu, Ida sane ngamel jagate, Tirtha pasucian iku, panglukatan tirtha suci, Pabersihan sarwa weci, lukat tityang sinamian, Jaba jero mangda landuh, jagat manggih trepti.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Belatungan merupakan kidung Wargasari yang berkaitan dengan daerah Belatungan. Wargasari adalah wirama yang sering digunakan sebagai kidung pembuka (pengawit) dalam rangkaian upacara. Kidung ini mengandung permohonan berkah dan perlindungan dari Bhatara yang berstana di kawasan Belatungan.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang mengalir. Gaya: Wargasari. Catatan: Digunakan sebagai kidung pembuka atau pengiring dalam upacara.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraBelatungan_Ref"/>

<owl:NamedIndividual rdf:about="#PemujaanPrabhuBelatungan_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariGedePulaki">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraGedePulaki_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanRsiNirartha_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan Rsi Nirartha di Dang Kahyangan Pulaki untuk kesejahteraan seluruh Bali.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Gede Pulaki)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dang Kahyangan</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA GEDE PULAKI
Pura Gede Pulakiku, Dang Kahyangan wastan nyane, 
Rsi Nirartha sane rawuh, maring Blangbangan puniki,
Karahayon jagat sami, nika tunas majeng lda, 
Bali ajug landuh, wibhuh Kita wrddhi.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Gede Pulaki dipersembahkan untuk Pura Pulaki, pura yang terletak di tebing pantai Buleleng yang dikenal sebagai tempat pertapaan Danghyang Nirartha. Pura ini terkenal dengan populasi kera yang dianggap sebagai penjaga pura. Kidung ini mengandung pemujaan kepada Bhatara Pulaki dan permohonan berkah kepada beliau yang dipandang sebagai penjaga wilayah barat laut Bali.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang. Gaya: Wargasari. Catatan: Untuk Piodalan di Pura Pulaki.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraGedePulaki_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariJagadNata">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraJagadNata_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanSangHyangWidhi_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada Sang Hyang Widhi Wasa sebagai penguasa jagat raya untuk memohon pancaran cahaya suci di dalam hati.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Jagad Nata)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA JAGAD NATA
Pupuh Wargasari.
1.	Pura Jagadnata luhur, linggih Sang Hyang Widhi ne, 
Ida ngawiwenang iku, nunas mangda Jagad Widdhi,
Ida ngemban dahat suci, luwih turing nirmala, 
Sinar maring kayun, wahyadyatmikaki.

2.	Sari amrta mangda wibhuh, sami landuh maring jagate, 
Nunas wasuhpada iku, nggen ngalebur inala iki,
Jaba jero mangda bersih, tirta suci pabersihan, 
Sami sampun puput, tityang sami pamit.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Jagad Nata dipersembahkan untuk Pura Jagad Nata, pura yang berstana Sang Hyang Widhi sebagai penguasa alam semesta (jagad nata berarti raja dunia). Kidung ini mengandung pemujaan kepada Tuhan Yang Maha Esa dalam manifestasi-Nya sebagai penguasa seluruh alam. Secara filosofis mencerminkan pengakuan tertinggi atas kekuasaan dan kemahakuasaan Sang Hyang Widhi Wasa.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Agung dan megah. Gaya: Wargasari. Catatan: Untuk upacara di Pura Jagad Nata.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraJagadNata_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanSangHyangWidhi_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariKerthaKawat">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraKerthaKawat_Ref"/>
  <digunakanPadaTahap rdf:resource="#IntiUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanBhataraSaksi_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan Tuhan sebagai saksi agung dan pemutus keadilan di Pura Kertha Kawat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Kertha Kawat)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dredaning semban inghulun, ring pura Kertha Kawate, Ida meraga pamutus, kanggen saksi maring bumi, Bhatara ngangganin sami, weruh ring kakandan jagat, Jagat Bali kukuh, manah sami suci.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Kertha Kawat mengandung makna berkah (kertha) dan kawat yang melambangkan ikatan atau koneksi spiritual. Kidung ini merupakan permohonan agar berkah Sang Hyang Widhi mengalir kepada semua umat seperti kawat yang menghubungkan antara dunia manusia dengan alam para dewa.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang. Gaya: Wargasari. Catatan: Digunakan dalam upacara Dewa Yadnya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraKerthaKawat_Ref"/>

<owl:NamedIndividual rdf:about="#PemujaanBhataraSaksi_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariMelanting">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraMelanting_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#NunasNugrahaSari_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dipanjatkan untuk memohon kelancaran rejeki dan kemakmuran (Amrta).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Melanting)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Kahyangan Jagat</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA MELANTING
Pura Mlanting Hyang Sinuhun, genah sari amrtane, 
Mangda ngicen nugraha Ratu, 
ring bhukpadan jong Bhatari, 
Tityang pedek sareng sami, manggihin kerahayuan, 
Krtha wrddhi landuh, pican Bhatara sami.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Melanting dipersembahkan untuk Pura Melanting yang berkaitan dengan Dewi Melanting sebagai dewi perdagangan dan kemakmuran dalam tradisi Hindu Bali. Kidung ini mengandung permohonan berkah kemakmuran, kelancaran usaha, dan rezeki yang halal dari Dewi Melanting.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang, penuh harapan. Gaya: Wargasari. Catatan: Untuk upacara di Pura Melanting.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraMelanting_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#NunasNugrahaSari_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariPabean">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraPabean_Ref"/>
  <digunakanPadaTahap rdf:resource="#NunasTirtha_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanHyangBaruna_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada Dewa Baruna untuk membersihkan dosa pikiran, perkataan, dan perbuatan.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Pabean)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pura Pabean puniku, linggih Hyang Baruna ne, Tirtha pangleburan letuh, mala Tri Kayane basmi, Kaya Wak lan Manah bersih, tityang sami matur suksma, Emban bhuwana agung, tityang manyiwi.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Pabean berkaitan dengan pura di kawasan Pabean, yang umumnya terletak di dekat area perdagangan atau pelabuhan. Kidung ini mengandung permohonan keselamatan dan perlindungan bagi semua kegiatan ekonomi dan perdagangan yang berlangsung di kawasan tersebut.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang. Gaya: Wargasari. Catatan: Untuk upacara di pura kawasan Pabean.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraPabean_Ref"/>

<owl:NamedIndividual rdf:about="#PemujaanHyangBaruna_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariPamuteran">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraPamuteran_Ref"/>
  <digunakanPadaTahap rdf:resource="#NunasTirtha_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#NunasTirthaPanglukatan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memohon tirtha penglukatan air panas di Pura Pamuteran untuk kejernihan hati.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Pamuteran)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Wargasari
Pura Pamuteran

Pura Pamuteran iku, nunas tirtha panglukata ne, 
toya suci toya panesku, linggih Bhatara Bhatari, 
Ida nyapuh mala sami, mangda bersih turing galang, 
galang maring kayun, matur suksma iki.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Pamuteran dipersembahkan untuk pura di kawasan Pemuteran, Buleleng. Kawasan ini dikenal dengan keindahan lautnya yang menjadi sumber kehidupan nelayan setempat. Kidung ini mengandung syukur dan permohonan berkah atas kekayaan laut serta keselamatan para nelayan yang menggantungkan hidupnya kepada laut.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang. Gaya: Wargasari. Catatan: Untuk Piodalan di pura kawasan Pemuteran.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraPamuteran_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#NunasTirthaPanglukatan_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_WargasariYehKatipat">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraYehKatipat_Ref"/>
  <digunakanPadaTahap rdf:resource="#NunasTirtha_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanBiyangPanjiSakti_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungWargasari_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menceritakan munculnya air suci melalui keris Biyang Panji Sakti sebagai sarana pembersihan.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari (Pura Yeh Katipat)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sejarah Buleleng</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pura toya katipat iku, linggih toya pabersihane, Sane dumun kekardiku, olih Biyang Panji Sakti, Katancep antuk keris, medal toyane nirmala, Jagat sami nyungsung, Buleleng manyiwi.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Yeh Katipat berkaitan dengan pura di kawasan Yeh Katipat. "Yeh" berarti air dalam bahasa Bali, sehingga kidung ini mengandung permohonan berkah air yang menyucikan dan menghidupkan. Secara filosofis mencerminkan hubungan sakral antara manusia Bali dengan sumber-sumber air sebagai anugerah alam yang harus dijaga.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang mengalir. Gaya: Wargasari. Catatan: Untuk upacara di pura kawasan Yeh Katipat.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PuraYehKatipat_Ref"/>

<owl:NamedIndividual rdf:about="#PemujaanBiyangPanjiSakti_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Wargasari_Pengawit">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <memilikiMakna rdf:resource="#PembukaUpacara_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya"/>
  <digunakanPadaUpacara rdf:resource="#UpacaraUmum_Ref"/>
  <digunakanDiPura rdf:resource="#PuraUmum_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung pembuka standar untuk memulai rangkaian nyanyian suci dalam upacara.</catatan>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wargasari Pengawit adalah kidung Wargasari yang difungsikan khusus sebagai kidung pembuka (pengawit) dalam rangkaian upacara. Pengawit berarti permulaan atau awal, sehingga kidung ini menandai dimulainya rangkaian nyanyian suci dalam suatu upacara. Secara tradisi, kidung pengawit berfungsi untuk mempersiapkan suasana sakral dan memusatkan perhatian seluruh peserta upacara.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Wargasari. Tempo: Sedang, mantap sebagai pembuka. Gaya: Wargasari. Catatan: Selalu dinyanyikan pertama kali sebagai pembuka rangkaian kidung dalam upacara.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wargasari</polaMelodi>
  <url_audio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://soundcloud.com/sayu-arnely/kidung-purwakaning-wargasari</url_audio>
  <platform_audio rdf:datatype="http://www.w3.org/2001/XMLSchema#string">soundcloud</platform_audio>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawitan Wargasari (Pengawit Kidung)</judulKidung>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Purwaka ning angripta rum, 
Ning wane ukir, 
kahadang labuh kartika, 
Panedenging sari, 
angayon tanguli ketur, 
Angringring jangga mure.</teksKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Panca Yadnya</sumberData>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PembukaUpacara_Ref">
  <urutanTahap rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</urutanTahap>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Wirama_Ragakusuma">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#IntiUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#DewaYadnya_Umum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PenyerahanDiri_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung yang melambangkan penyerahan diri sepenuhnya di kaki teratai Tuhan.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Ragakusuma (Pamujian Ring Bhatara)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gita Pemujaan</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Om sembah ning anasraye carana pangkaja bhuwana patiki tinghali, wahyawahya panembah ingwang iki, teka satata kinabhaaktyan inghulun, byaktabyakta kita sarat kita hurip ning ahurip agawe hala hayu, sang manggeh pinake stining maha lilangnilaraken dasendriya.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wirama Ragakusuma merupakan versi wirama (melodi/irama) dari kidung Ragakusuma. Wirama dalam konteks kidung Bali merujuk pada pola melodi dan ritme yang spesifik. Kidung ini mengandung keindahan musikal yang tinggi karena menggabungkan wirama yang rumit dengan lirik yang bermakna mendalam sebagai persembahan estetis kepada para dewa.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Ragakusuma. Tempo: Sedang, indah dan bervariasi. Gaya: Sekar Alit. Catatan: Memerlukan kemahiran khusus dalam melantunkan wirama yang benar.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ragakusuma</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PenyerahanDiri_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Wirama_Saraswati">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#IntiUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#HariRayaSaraswati_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanIlmuPengetahuan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan khusus kepada Dewi Saraswati untuk memohon kecerdasan dan pemahaman sastra.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama (Pengastawan Sang Hyang Saraswati)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lontar Saraswati</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sanghyang Wagiswarindah lihati satata bhaktingkwi jong Dhatrdewi, pinrih ring citta munggwingsarasija ri dalem twas lanenastawangku, nityawehang waranugraha kaluputa ring duhka sangsara wighna, lawan wruheng sastra sakala gunaning janma tapwan haneweh.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wirama Saraswati merupakan kidung dengan wirama khusus untuk pemujaan Dewi Saraswati. Berbeda dengan Kidung Saraswati biasa, versi wirama ini menekankan pada keindahan melodi yang mencerminkan Dewi Saraswati sebagai dewi seni dan musik. Kidung ini merupakan persembahan seni tertinggi kepada sang dewi pelindung ilmu dan kesenian.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Saraswati. Tempo: Sedang, indah dan melodis. Gaya: Sekar Alit. Catatan: Dinyanyikan pada perayaan Hari Raya Saraswati dengan penekanan pada keindahan melodinya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Saraswati</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#HariRayaSaraswati_Ref"/>

<owl:NamedIndividual rdf:about="#PemujaanIlmuPengetahuan_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Wirama_Sardulawikridita">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#IntiUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#DewaYadnya_Umum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PenghormatanBhataraHari_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pemujaan kepada Bhatara Hari (Wisnu/Tuhan) yang berstana di dalam hati umat.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Sardulawikridita</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gita Pemujaan</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sembahning hulun ing Bhatara Hari sarw wajnatma Bhuh nityasa, sang tan seng hrdayan tatikta tulusa ngke supratiste namer, ring wahyastuti sembahing hulun ijong Sanghyang sahasrang suman, dadya prakrta nitisastra hiniket lambang winakteng praja.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Wirama Sardulawikridita menggunakan wirama Sardulawikridita yang berasal dari tradisi kakawin Jawa-Bali. Sardulawikridita berarti "gerakan macan besar" yang menggambarkan keagungan dan kekuatan. Dalam konteks pemujaan, kidung ini melambangkan kekuatan dan kebesaran Sang Hyang Widhi yang tak tertandingi, dilantunkan dengan pola melodi yang khas dan menantang.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Sardulawikridita. Tempo: Sedang cenderung cepat, dinamis. Gaya: Sekar Alit. Catatan: Memerlukan latihan khusus karena wiramanya yang kompleks.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sardulawikridita</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PenghormatanBhataraHari_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_ManusaYadnya_AlisAlisIjo">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Griya_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#ManusaYadnya_Ref"/>
  <memilikiJenisYadnya rdf:resource="#ManusaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#KesucianWiku_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung yang menggambarkan pertemuan murid dengan gurunya (Dukuh), digunakan dalam prosesi Manusa Yadnya.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Alis-Alis Ijo Bawak</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Manusa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ALIS-ALIS IJO BAWAK
1.	Prapteng dukuh ling sang sunia, apolah age sira tuan, Endi sinangkang ranak, ingong, yaya semu newirage, minda kania ami rangrong, kasalulutan winadon, duh tuan kaki ranak ingsun, alungguh maring patani, manawi sira kaleson.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Alis-Alis Ijo dalam konteks Manusa Yadnya berfungsi sebagai kidung pemberkahan bagi manusia yang menjalani upacara-upacara siklus kehidupan. Dalam Manusa Yadnya, kidung ini menyambut kehidupan baru dan perjalanan hidup manusia dengan doa dan restu. Filosofinya mencerminkan pandangan Hindu bahwa setiap tahapan kehidupan manusia adalah anugerah yang patut disyukuri.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Alis-Alis Ijo. Tempo: Sedang, ceria dan penuh harapan. Gaya: Sekar Alit. Catatan: Digunakan dalam berbagai upacara Manusa Yadnya sebagai kidung pemberkahan.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alis-Alis Ijo</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#ManusaYadnya_Ref">
  <rdf:type rdf:resource="#JenisYadnya"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_ManusaYadnya_Kusumarabhasa">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Rumah_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Pawiwahan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#ManusaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Keharmonisan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menggambarkan keindahan alam di kala fajar, melambangkan harapan dan awal baru bagi pasangan pengantin.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Kusumarabhasa (Widaragumulung)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Manusa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">WIDARAGUMULUNG/ KUSUMARABHASA
Pawiwahan
- 00/-00/-00/000/0-0/0-0/00=20

1.	Meh rahina semu bang Hyang aruna kadi netraning ogha rapuh,
Sabda ni kokila ring kanigara saketer ni kidung ning akung,
Lwir wuwusing wini panca papetaking ayam wana ring pagagan,
Mrak anguhuh brhramarangrabhasa kusuma ring parahasyan arum.

2.	Gandha ni jangga menur nikang alaya latamrik angumkuma mar, Lot linawad ni kukusning angusuma ri wimba Bhatara Gana, Molih ulih wangining sulasih agaru candana gulgula mar, Sri gadhinging harepan wilaja mangalasa manegehnegehi.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Kusumarabhasa mengandung makna "wangi bunga" (kusuma = bunga, rabhasa = wangi/harum). Dalam Manusa Yadnya, kidung ini menggambarkan harapan agar manusia yang menjalani upacara dapat tumbuh seperti bunga yang harum dan bermanfaat bagi sekitarnya. Secara filosofis mencerminkan doa agar kehidupan manusia penuh dengan kebaikan dan keindahan yang menyebarkan keharuman seperti bunga.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Kusumarabhasa. Tempo: Sedang, indah dan wangi. Gaya: Sekar Madya. Catatan: Digunakan dalam upacara Manusa Yadnya seperti Pawiwahan dan Matetah.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kusumarabhasa</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Rumah_Ref">
  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pawiwahan_Ref">
  <rdf:type rdf:resource="#UpacaraPancaYadnya"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_ManusaYadnya_MandaMalon">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Rumah_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Pawiwahan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#ManusaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Penyatuan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Digunakan dalam puncak pernikahan, mengandung filosofi tentang karma dan pengendalian diri dalam rumah tangga</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Manda Malon (Pawiwahan)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Manusa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MANDA MALON
000/0-07-00/0-0/0-0/00=17

1.	Hana mara janma tan pamihutang brata yoga tapa, Angetul aminta wirrya sukaning Widhi sahasika, binalik aken purih nika lewih tinamunya lara, Sinakitaning rajah tamah inandhehaning prihati.
2.	Kadi hana purwwa karma dinalih sang akaryya hayu, Ulah apageh magegwana rasagama buddhi tepet, ya juga sudhira munggu ring manah nira sang nipuna, Karana nikang sukabhyudaya niskala yan katemu.
3.	Syapa kari tan temung hayu masadhana sarwwa hayu, Niyata katemwaning hala masadhna sarwwa hala, Tewas alisuh manangsaya purakrita tapa tinut,
Sakarepan kasuddha maka darsana Pandhusuta.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Manda Malon menggunakan wirama yang mengalir dengan lambut. "Manda" berarti lambat atau lembut, sehingga kidung ini dilantunkan dengan penuh kelembutan dan kasih sayang. Dalam Manusa Yadnya, kidung ini mencerminkan kasih sayang yang mendalam dari keluarga dan komunitas kepada individu yang sedang menjalani upacara siklus kehidupan.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Manda Malon. Tempo: Lambat, lembut dan penuh kasih. Gaya: Sekar Alit. Catatan: Cocok untuk upacara yang bersifat intim dan keluarga.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Manda Malon</polaMelodi>
</owl:NamedIndividual>

