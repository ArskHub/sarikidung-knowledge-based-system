<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Adri_NunasTirtha">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUmum_Ref"/>
  <digunakanPadaTahap rdf:resource="#NunasTirtha_Ref"/>
  <digunakanPadaUpacara rdf:resource="#UpacaraUmum_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PembersihanLara_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan saat memohon air suci (wasuh cokor) untuk melebur segala penyakit, kesialan, dan kekotoran batin.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Adri Rerepen (Nunas Tirtha)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NUNAS TIRTHA (WASUH COKOR)
Pupuh Adri Rerepen.
Tirtha Uttama sakti manerus, paican kaulane mangkin, ne sandhi masupati, panyupatan lara agung, salwiring lara kasapuh, hilang moksa maring sunia, letuh hilang ala
dudus, katibenin tirtha, paican Ida Bhatara.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Adri Nunas Tirtha menggunakan wirama Adri untuk mengiringi permohonan tirtha (air suci). Kidung ini menggambarkan permohonan air suci yang kokoh dan sungguh-sungguh seperti gunung. Tirtha yang dimohon melalui kidung ini diyakini memiliki kekuatan penyucian yang lebih kuat karena disertai dengan doa dan nyanyian suci.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Adri. Tempo: Lambat, khidmat. Gaya: Sekar Alit. Catatan: Khusus dinyanyikan pada tahap nunas tirtha.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adri</polaMelodi>
</owl:NamedIndividual>

