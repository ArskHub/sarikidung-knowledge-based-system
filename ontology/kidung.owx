<owl:NamedIndividual rdf:about="#Kidung_BhutaYadnya_DemungSawit">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#HalamanRumah_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Mecaru_Ref"/>
  <memilikiJenisYadnya rdf:resource="#BhutaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#KeseimbanganAlam_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menggambarkan tatanan alam melalui cerita Tantri, digunakan saat persiapan caru.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Demung Sawit (Tantri)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Panca Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Demung Sawit (Tantri)
1.	Gumanti kawuwusan sri Singa di Prabu, pinarek ri soring jati, riareping guh wara mangkuk, kweh bala sona makadi, ken sambada ngrep anyongkong.
2.	Ulahing swara mongsil sawanyang alulu, Anglincak aswacengil, Akrah larut angawung, Suka sri mrega dipati,</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Demung Sawit merupakan kidung yang digunakan dalam upacara Bhuta Yadnya untuk menetralkan kekuatan negatif (bhuta kala). Demung adalah salah satu instrumen gamelan, sedangkan sawit memiliki makna dalam konteks pemujaan. Kidung ini memiliki kekuatan spiritual untuk memanggil dan menenangkan kekuatan-kekuatan alam yang bersifat kasar agar tidak mengganggu kehidupan manusia.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Demung Sawit. Tempo: Sedang, berirama kuat. Gaya: Sekar Alit. Catatan: Dinyanyikan dalam upacara Bhuta Yadnya seperti Caru dan Tawur.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Demung Sawit</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Mecaru_Ref">
  <rdf:type rdf:resource="#UpacaraPancaYadnya"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_BhutaYadnya_Jerum">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#HalamanRumah_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Mecaru_Ref"/>
  <memilikiJenisYadnya rdf:resource="#BhutaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PenyucianBhuta_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung penyucian untuk menenangkan kekuatan Bhuta agar kembali ke sifat dewa (Somya).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Jerum</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Bhuta Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Jerum
3.	Tangeh anamun turida, salimun tan kasalimburr, prakerti abayeng dangu, tumuwuh ta andadi wwong, rasa tan dadi ageman, marma nira mesreng kidung, tan anuting pupuh bhasa.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Jerum digunakan dalam upacara Bhuta Yadnya untuk menghormati dan menenangkan Bhuta Kala yang menguasai persimpangan jalan dan tempat-tempat tertentu. Jerum memiliki makna yang berkaitan dengan permohonan agar para bhuta kala bersedia menerima persembahan dan tidak mengganggu kehidupan manusia. Secara filosofis mencerminkan konsep keseimbangan antara kekuatan positif dan negatif di alam semesta.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Jerum. Tempo: Sedang, berwibawa. Gaya: Sekar Alit. Catatan: Dinyanyikan dalam upacara caru dan pecaruan.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Jerum</polaMelodi>
</owl:NamedIndividual>

