<owl:NamedIndividual rdf:about="#Kidung_ResiYadnya_RagaWangi">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#Griya_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#UpacaraAbhiseka_Ref"/>
  <memilikiJenisYadnya rdf:resource="#RsiYadnya_Ref"/>
  <memilikiMakna rdf:resource="#KesucianWiku_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali/Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menggambarkan sifat seorang Wiku (Pendeta) yang telah memahami hakikat bumi dan langit (kosmologi suci).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Raga Wangi</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Resi Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Raga Wangi :
3.	Nihan polahing sang tatas wiku, 
nawang bumi langit, 
dija ento warange, 
punika tegakan wiku,
Wulan Surya lawan Wintang, 
sampun kawas ne ring langit, 
ndi pamating ipun, 
iwang suruping banyu asri.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Raga Wangi mengandung makna "jiwa yang harum" (raga = jiwa/tubuh, wangi = harum). Dalam Rsi Yadnya, kidung ini menggambarkan keharuman jiwa para rsi yang telah menjalani disiplin spiritual yang tinggi. Kidung ini juga merupakan permohonan agar upacara Rsi Yadnya yang dilaksanakan menghasilkan jiwa-jiwa yang harum dan bermartabat tinggi.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Raga Wangi. Tempo: Sedang, harum dan anggun. Gaya: Sekar Alit. Catatan: Dinyanyikan dalam upacara Rsi Yadnya sebagai ungkapan penghormatan.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Raga Wangi</polaMelodi>
</owl:NamedIndividual>

