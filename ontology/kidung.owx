<owl:NamedIndividual rdf:about="#Kidung_PitraYadnya_AswaLalita">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#RumahDuka_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#NangininSawa_Ref"/>
  <memilikiJenisYadnya rdf:resource="#PitraYadnya_Ref"/>
  <memilikiMakna rdf:resource="#MembangunkanJenazah_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan saat prosesi menyucikan jenazah, bermakna melepaskan keterikatan duniawi.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Aswa Lalita (Nanginin Sawa)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Pitra Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nanginin Sawa ( Layon)
WIRAMA ASWA LALITA

1.	Matang i kakanta matya lepaseng pasir ta juga kenakang 
kwa leleha,
Rurubana puspa padapa sawangku satpada
marakusanangisana,
Tengah akeneng tsik adhu tekapning anghanut 
aram wanasana sumar, 
Muliha mareng smaralaya maran ri janma nika
kaptyaning wwang ahajeng.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Aswa Lalita merupakan kidung yang menggunakan wirama Aswa Lalita yang memiliki karakter mengalir bebas. Dalam konteks Pitra Yadnya, kidung ini menggambarkan perjalanan atma leluhur yang bebas menuju alam keabadian. "Aswa" berarti kuda, melambangkan kecepatan dan kebebasan, sementara "lalita" berarti indah, sehingga kidung ini melukiskan keindahan perjalanan sang atma menuju moksa.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Aswa Lalita. Tempo: Sedang mengalir. Gaya: Sekar Madya. Catatan: Dinyanyikan dalam upacara Pitra Yadnya khususnya saat prosesi pengiring.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aswa Lalita</polaMelodi>
</owl:NamedIndividual>

