<owl:NamedIndividual rdf:about="#Kidung_BhutaYadnya_Saronca">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PerempatanAgung_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Mecaru_Ref"/>
  <memilikiJenisYadnya rdf:resource="#BhutaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#MengharmoniskanBhuta_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Menggambarkan prosesi Mahoma dan pemberian caru kepada Pisaca serta Raksasa.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Saronca</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Bhuta Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Saronca :
4.	Sanjining yajna ta humadhang,
 Sriwreksa samiddha puspa gandha phala,
 Dadhi ghreta kresna tila madhu,
 Mwang kumba kusagra wreti wetih.

5.	Lumekas ta sira mahoma,
 Pretadi pisaca raksasa minantran,
 Bhuta kabeh I nilagaken
 Asing mamihghna rikang yajna.

6.	Sanghyang kunda pinuja,
 Caru makulilingan samatsya mangsa dadhi,
 Kalawan sekul niwediya
 Inames salwir nikang marasa.
7.	Sampun pwa sira pinuji,
 Bhinojanan sang maharesi paripurnna,
 Kalawan sang Wiku saksi,
 Winursita dinaksinan ta sira.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Saronca merupakan kidung penting dalam upacara Bhuta Yadnya yang memiliki kekuatan untuk memanggil dan mendamaikan para bhuta kala. Kidung ini mengandung mantra-mantra dan formula ritual yang dipercaya dapat menetralisir pengaruh negatif dan menciptakan keseimbangan antara alam sekala (nyata) dan niskala (gaib). Penggunaan kidung Saronca harus dilakukan oleh orang yang paham dengan tatacara ritualnya.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Saronca. Tempo: Sedang hingga cepat, berirama kuat. Gaya: Sekar Alit. Catatan: Memerlukan pemahaman khusus tentang ritual Bhuta Yadnya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Saronca</polaMelodi>
</owl:NamedIndividual>

