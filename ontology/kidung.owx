<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_MijilYehLesung">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraYehLesung_Ref"/>
  <digunakanPadaTahap rdf:resource="#NunasTirtha_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanTirthaSolasWarna_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Memuja air suci 11 warna untuk penglukatan (penyucian fisik dan mental).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pura Yeh Lesung)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PURA TIRTHA KALESUAN/PURA YEH LESUNG
1.	Pura Lesung, linggih masucian iki, toya hening reko, Solas warna paideran nyane, ledang Ratu, Maicayang suci,
Nglukat tityang sami, jaba jero manggih hayu.

2.	Wantah Ratu, ngardi kitan gumi, mangda kasidan don, Asung asih Bhatara ne, mapi suguh, bhakti manah eling, Tityang sareng sami, letuhe lara kasapuh.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Yeh Lesung merupakan kidung pemujaan yang berkaitan dengan pura di kawasan Yeh Lesung. Kidung ini mengandung makna permohonan berkah air suci (yeh) yang mengalir dari sumber mata air yang dianggap sakral dalam tradisi Hindu Bali. Filosofinya berkaitan erat dengan konsep Tirtha sebagai air penyucian yang membersihkan jiwa dari kekotoran.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang. Gaya: Sekar Madya. Catatan: Untuk Piodalan di pura kawasan Yeh Lesung.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

