<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_PengayatBhataraSucyandewi">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraAndakasa_Ref"/>
  <digunakanDiPura rdf:resource="#PuraBesakih_Ref"/>
  <digunakanDiPura rdf:resource="#PuraBukitPengelengan_Ref"/>
  <digunakanDiPura rdf:resource="#PuraGoaLawah_Ref"/>
  <digunakanDiPura rdf:resource="#PuraLempuyang_Ref"/>
  <digunakanDiPura rdf:resource="#PuraUlunDanuBatur_Ref"/>
  <digunakanDiPura rdf:resource="#PuraUluwatu_Ref"/>
  <digunakanDiPura rdf:resource="#PuraWatukaru_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Pemujaan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama Sucyandewi. Menyebut manifestasi Bhatara di Kahyangan Jagat</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pengayat ring Bhatara</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Panca Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.Cakra Bhatara Wisnu ring Pura Ulun Danu Batur, 
Trisula Bhatara Sambu ring Pura Besakih, 
Genta Bhatara Iswara ring Pura Lempuyang, 
Dupa Bhatara Maheswara ring Pura Goalawah,
2.Gada Bhatara Brahma ring Pura Andakasa, 
Muksala Bhatara Rudra ring Pura Uluwatu, 
Nagapasa Bhatara Mahadewa ring Pura Watukaru, 
Angkus Dewa Sangkara ring Pura Bukit Pengelengan</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Pengayat Bhatara Sucyandewi adalah kidung penyambutan khusus untuk Bhatara Sucyandewi, manifestasi dewi kesucian. Sucyandewi merupakan dewi yang berkaitan dengan kemurnian dan penyucian spiritual. Kidung ini dilantunkan saat pratima Sucyandewi dibawa dalam prosesi untuk menyambut kehadiran beliau dengan penuh hormat dan bhakti.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Pengayat. Tempo: Sedang, anggun dan bersih. Gaya: Sekar Alit. Catatan: Khusus dinyanyikan saat pengayat Bhatara Sucyandewi.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pengayat</polaMelodi>
</owl:NamedIndividual>

