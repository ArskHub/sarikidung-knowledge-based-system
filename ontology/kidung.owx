<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_AdriGanesha">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraUmum_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanDewaGana_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali Kawi</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan untuk memohon perlindungan dan penghapusan rintangan (Vighneswara).</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Adri (Ngayat Bhatara Gana)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sastra Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ganesha maha tedung iku, tedung para bhaktane, Mahotama putra Gauri, putra Uma Parwati kasub, Ganesha putra Siwa hayu, Dewa Gana jati uttama.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Adri Ganesha adalah kidung pemujaan khusus untuk Dewa Ganesha, dewa kebijaksanaan dan penghilang rintangan yang digambarkan berkepala gajah. Adri berarti gunung, sehingga kidung ini menggambarkan Ganesha sebagai kekuatan yang sekokoh gunung. Dalam tradisi Hindu Bali, Ganesha selalu dipuja pertama kali sebelum memulai suatu kegiatan penting agar segala rintangan disingkirkan.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Adri. Tempo: Sedang, mantap dan kokoh. Gaya: Sekar Alit. Catatan: Dinyanyikan sebagai pemujaan awal kepada Dewa Ganesha sebelum upacara dimulai.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adri</polaMelodi>
</owl:NamedIndividual>

