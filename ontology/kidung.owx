  <rdf:type rdf:resource="#PuraTempatPelaksanaan"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PemujaanTirthaSolasWarna_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Mijil_BantenPenganyar">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#NgaturangBanten_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#PersembahanAnyar_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dinyanyikan saat mempersembahkan sesaji penganyar, memohon maaf atas segala kekurangan sarana.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pupuh Mijil Alus Manis (Ngaturang Banten Penganyar)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sampun katur, banten penganyarki, kirang langkung ento, nunas agung, pengampura ne, Bhetaraku, tan upadrawaki, ledang Ida nyari, Pada kenak pada kenyung.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Banten Penganyar adalah kidung yang dinyanyikan saat prosesi ngaturang banten penganyar, yaitu persembahan tambahan yang dipersembahkan kepada Bhatara di pura. Banten penganyar merupakan wujud bhakti yang tulus sebagai ungkapan terima kasih atas berkah yang telah diterima. Kidung ini mengiringi prosesi persembahan banten sebagai lantunan doa yang memperkuat nilai spiritual dari persembahan tersebut.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang khidmat. Gaya: Sekar Madya. Catatan: Dinyanyikan saat prosesi ngaturang banten penganyar.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#NgaturangBanten_Ref">
  <urutanTahap rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</urutanTahap>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#PersembahanAnyar_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_Mijil_Pengastawan">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanPadaTahap rdf:resource="#IntiUpacara_Ref"/>
  <memilikiMakna rdf:resource="#PemujaanMahaSuci_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarMadya"/>
  <digunakanPadaUpacara rdf:resource="#UpacaraUmum_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ungkapan bakti yang sangat rendah hati dihadapan Sang Hyang Maha Suci.</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil Alus Manis (Pengastawan Ring Bhatara)</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Dewa Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Singgih Ratu, Sanghyang Maha Suci, bhaktin tityang nyokor, Ring bhukpadan singgih Bhatara ne, mugi Ratu ledang manywecanin, kaulane sami, mogi molih mangguh hayu.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Mijil Pengastawan merupakan kidung yang dinyanyikan saat tahap pengastawan, yaitu prosesi pemujaan dan penyembahan kepada Bhatara atau Ida Sang Hyang Widhi. Pengastawan adalah bagian inti dari persembahyangan Hindu di mana umat menghaturkan puja dan bakti tertinggi. Kidung ini berfungsi sebagai sarana untuk mempersiapkan jiwa dan pikiran agar sepenuhnya hadir dalam pemujaan suci.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Mijil (8i-8o-8e-7u-8i-6i). Tempo: Sedang, penuh konsentrasi spiritual. Gaya: Sekar Madya. Catatan: Dinyanyikan pada tahap pengastawan dalam rangkaian upacara.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mijil (8i-8o-8e-7u-8i-6i)</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#IntiUpacara_Ref"/>

<owl:NamedIndividual rdf:about="#PemujaanMahaSuci_Ref"/>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_NunasTirthaRingBhatara">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraDesa_Ref"/>
  <digunakanPadaTahap rdf:resource="#PuncakUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Penyucian_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Permohonan tirtha dari pancoran empat penjuru dan tengah. Digunakan dalam upacara Dewa Yadnya</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nunas Tirtha Ring Bhatara</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Panca Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nunas Tirtha ring Bhatara

Reng Wirama Wawirat:
- --/00-/0 0/00-/000/000/-0-/00=23
1.	Saking purwa pancoran salaka tirthanya pawitra
tinumbuhan tunjung putih,
Saking daksina pancoran temaga tirthanya 
sanjiwani tinumbuhan tunjung bang, 
Saking kulon pancoran mas tirthanya
Kundalini tinumbuhan tunjung kuning,
Saking utara pancoran wesi tirthanya
kamendalu tinumbuhan tunjung ireng.
Saking tengah pancoran petak tirthanya
sudhamala tinumbuhan tunjung warna.

Pupuh Warga Sari
2.	Turun tirta saking luhur,
tirthan Panca Dewatane,
Wisnu tirtha kamendalu,
Hyang Iswara sanjiwani,
Mahadewa kundalini,
Hyang Brahma tirtha pawitra.
Hyang Siwa pamuput,
Amretha kinardi.

3.	Seger-eger kamandalu,
sanjiwani pikukuhe,
ngardi jagat pang rahayu,
pawitra kasucian hati,
trepti santi kundalini
sadya sakala niskala,
amertha nama rum,
lamakang pinuji.

4.	Turun tirtha saking luhur,
Manyıratın pemangkune,
Mekalangan muncrat mumbul,
Mapan tirtha amerta jati,
Paican Bhatara sami,
Panyupatan dasa mala,
Apang sida lebur,
Malane ring bumi.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Nunas Tirtha Ring Bhatara adalah kidung khusus untuk tahap permohonan tirtha (air suci) kepada Bhatara. Tirtha merupakan salah satu sarana terpenting dalam upacara Hindu Bali sebagai media penyucian jiwa dan raga. Kidung ini mengandung permohonan yang tulus agar Bhatara berkenan memberikan air suci yang mengandung kekuatan spiritual untuk menyucikan para peserta upacara dari segala kekotoran.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Khusus nunas tirtha. Tempo: Lambat dan khidmat. Gaya: Sekar Alit. Catatan: Dinyanyikan khusus pada tahap nunas tirtha dalam upacara Dewa Yadnya.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nunas Tirtha</polaMelodi>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Penyucian_Ref">
  <rdf:type rdf:resource="#MaknaKidung"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Kidung_DewaYadnya_PengaksamaBhataraBremara">
  <rdf:type rdf:resource="#KidungPancaYadnya"/>
  <digunakanDiPura rdf:resource="#PuraDesa_Ref"/>
  <digunakanDiPura rdf:resource="#PuraKahyanganJagat_Ref"/>
  <digunakanDiPura rdf:resource="#PuraKahyanganTiga_Ref"/>
  <digunakanDiPura rdf:resource="#PuraPuseh_Ref"/>
  <digunakanPadaTahap rdf:resource="#AwalRangkaianUpacara_Ref"/>
  <digunakanPadaUpacara rdf:resource="#Piodalan_Ref"/>
  <memilikiJenisYadnya rdf:resource="#DewaYadnya_Ref"/>
  <memilikiMakna rdf:resource="#Pemujaan_Ref"/>
  <memilikiJenisKidung rdf:resource="#KidungSekarAlit_Ref"/>
  <bahasa rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bali</bahasa>
  <catatan rdf:datatype="http://www.w3.org/2001/XMLSchema#string">- --/00-/0-/00-/--/--0/0=19</catatan>
  <judulKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pengaksama ring Bhatara Pupuh Bremara</judulKidung>
  <sumberData rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Buku Kidung Panca Yadnya</sumberData>
  <teksKidung rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.	Om, Om, sembah i ketunan, 
dumadak jua keaksi, 
mungguhing pangebaktin tityang, 
dyastu langkung tuna sami, 
pakirang arta wibawa, 
nista solah lawan wuwus, 
muwuh banget hina bhudi.

2.	Kewanten sredaning manah, 
miwah katlebaning hati, 
kalawan eling tan pegat,
kanggen menyanggra manyuhun, 
Swecan I Ratu sang Iwih.

3.	I Ratu langkung pawikan, 
ring manah sarwa dumadi, 
ne jati kalawan boya, 
ne corah lan bakti mulus, 
ne patut kalawan rusit.

4.	Apan paduka Bhatara, 
ne mula nodyanin gumi, 
weruh ring sekandan jagat, 
saluwir ne wus ngelangkung, 
mangkin miwah ne kauri.

5.	Sakala lawan niskala, 
Bhatara ngangganin sami, 
Botika ganal Bhatara, 
ginika alit sang luwih, 
wisnawa suksman Bhatara, 
Brahmi niskalam i Ratu, 
pepek sami karagin.

6.	Mugi tan kecakra bhawa, tityang i ketutnan sami, 
Kaya Wak lan Manah, langgeng ngulami Hyang
Widhi, sang suksma mahacintya, nirbana Siwa 
kasengguh, singidan ring tampak aksi.

7.	Apan pada kaswecanan, dyastu tambet sami-sami, 
Engaturang sarwa nista, sekar sane gelis alum, 
doh langkung ring padma hredhi.

8.	Sok wenten anggen sadana, nunas nugraha
Hyang Widhi, kang mungguh ring wasuh pada, ne suci
Mangardi luwung, dirgayusa hayu wrédhi.

9.	Ong ksama swamam pukulan, 
sadosa Tri Kayane, 
manusan ira hati jugul, 
pangkah mangaturang gurit, 
ri pada dwaya sang luwih,
sedanan ingong aneda, 
sih ira Hyang kasuhun, 
moga sida nangun trepti.

10. Pengaksamane kaluhur, 
nunas wara nugrahane, 
menawi kirang ne katur, 
agung sinampura ugi, 
canange asebit sari, 
apang ica Ida nonton, 
nodia saking luhur, 
mamuputang sami.

11.	Awighna ta pukulun, 
angarcana Bhatarane, 
angayap ngaturang kukus, 
maduluran pangebakti, 
miwah sahananing suci 
apang Ida ica nonton,
turun saking luhur, 
Kaula manangkil.</teksKidung>
  <statusValidasi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Belum Divalidasi</statusValidasi>
  <maknaMendalam rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kidung Pengaksama Bhatara Bremara adalah kidung permohonan maaf yang khusus ditujukan kepada Bhatara Bremara. Bremara berkaitan dengan manifestasi Dewa sebagai penjaga dan pelindung. Kidung ini memohon agar Bhatara Bremara berkenan mengampuni segala kesalahan dan kelalaian yang terjadi dalam pelaksanaan upacara, serta memohon izin untuk melanjutkan rangkaian persembahan.</maknaMendalam>
  <teknikMenyanyi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wirama: Pengaksama. Tempo: Lambat penuh kerendahan hati. Gaya: Sekar Alit. Catatan: Dinyanyikan pada tahap pengaksama khusus untuk Bhatara Bremara.</teknikMenyanyi>
  <polaMelodi rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pengaksama</polaMelodi>
</owl:NamedIndividual>

